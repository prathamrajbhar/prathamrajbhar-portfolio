generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Site Settings (Singleton) ───────────────────────────────────────────────

model SiteSettings {
  id          String   @id @default("singleton")
  name        String
  title       String
  bio         String
  email       String
  github      String?
  linkedin    String?
  twitter     String?
  resumeUrl   String?
  avatarUrl   String?
  heroTagline String?
  openToWork  Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  content       String        @default("")
  subtitle      String?
  role          String?
  client        String?
  category      String?
  timeline      String?
  year          String?
  problem       String?
  solution      String?
  impact        String?
  features      String[]
  outcomes      String[]
  techStack     String[]
  liveUrl       String?
  githubUrl     String?
  imageUrl      String?
  galleryImages String[]
  tags          String[]
  featured      Boolean       @default(false)
  status        String        @default("completed")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  projectLinks  ProjectLink[]
}

model ProjectLink {
  id        String  @id @default(cuid())
  label     String
  url       String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String
  contentFormat String   @default("mdx")
  coverImage    String?
  published     Boolean  @default(false)
  readingTime   Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tags          String[]
}

// ─── Experience ──────────────────────────────────────────────────────────────

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  location    String?
  type        String   @default("Full-time")
  startDate   DateTime
  endDate     DateTime?
  current     Boolean  @default(false)
  description String
  skills      String[]
  logoUrl     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

// ─── Skills ──────────────────────────────────────────────────────────────────

model Skill {
  id       String  @id @default(cuid())
  name     String  @unique
  category String
  iconUrl  String?
  order    Int     @default(0)
}

// ─── Contact Messages ────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Hackathons ──────────────────────────────────────────────────────────────

model Hackathon {
  id          String   @id @default(cuid())
  title       String
  project     String
  role        String?
  date        DateTime
  location    String?
  result      String?
  link        String?
  description String
  image       String?
  createdAt   DateTime @default(now())
}

// ─── Certifications ──────────────────────────────────────────────────────────

model Certification {
  id           String   @id @default(cuid())
  name         String
  issuer       String
  date         DateTime
  url          String?
  credentialId String?
  image        String?
  createdAt    DateTime @default(now())
}

// ─── Page Views (Analytics) ──────────────────────────────────────────────────

model PageView {
  id    String @id @default(cuid())
  path  String @unique
  count Int    @default(0)
}
