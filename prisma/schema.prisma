generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Site Settings (Singleton) ───────────────────────────────────────────────

model SiteSettings {
  id                String   @id @default("singleton")
  name              String
  title             String?  @default("Software Engineer")
  bio               String?
  email             String
  location          String?
  
  // Hero Section
  heroTitle         String?  @default("Engineering Great Websites.")
  heroTagline       String?  @default("FULL-STACK ENGINEER")
  heroBio           String?
  avatarUrl         String?
  resumeUrl         String?
  
  // About Section
  aboutTitle        String?  @default("Building things that work well.")
  aboutGoalTitle    String?  @default("My Goal")
  aboutGoalDesc     String?
  yearsOfExperience String?  @default("2+")
  aboutStatsWork    String?  @default("2+")
  aboutStatsProjects String? @default("15+")
  aboutStatsCommitment String? @default("100%")
  
  // Projects Section
  projectsTitle     String?  @default("My Projects")
  projectsSubtitle  String?  @default("My Work")
  projectsDesc      String?  @default("I have built many projects that are fast and easy to use.")

  // Home Page Additional Sections
  homeWorkTitle     String?  @default("Work History")
  homeWorkSubtitle  String?  @default("History")
  homeWorkDesc      String?
  homeBlogTitle     String?  @default("Recent Posts")
  homeBlogSubtitle  String?  @default("Blog")

  // Hero Typing Roles (comma-separated)
  heroRoles         String?

  // Blog Page
  blogTitle         String?
  blogSubtitle      String?
  blogIntro         String?

  // Experience Page
  experienceHeroTitle   String?
  experienceHeroDesc  String?

  // Education Page
  educationHeroDesc String?

  // About Extra Bio
  aboutExtraBio     String?

  // Contact CTA
  contactCtaTitle   String?  @default("Have a project in mind?")
  contactCtaDesc    String?  @default("I'm currently open for freelance work and new jobs. Let's build something great together.")
  
  // Links
  github            String?
  linkedin          String?
  twitter           String?
  
  // Footer
  footerTitle       String?  @default("Ready to bring your ideas to life?")
  footerBio         String?  @default("I build fast, high-quality websites and apps that are easy to use.")
  
  // SEO
  seoTitle          String?
  seoDescription    String?
  seoKeywords       String?
  ogImage           String?
  
  openToWork        Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

// ─── Services ────────────────────────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String?  @default("zap")
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([order])
}

// ─── Projects ────────────────────────────────────────────────────────────────

model Project {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  content       String        @default("")
  subtitle      String?
  role          String?
  client        String?
  category      String?
  timeline      String?
  year          String?
  problem       String?
  solution      String?
  impact        String?
  features      String[]
  outcomes      String[]
  techStack     String[]
  liveUrl       String?
  githubUrl     String?
  imageUrl      String?
  galleryImages String[]
  tags          String[]
  featured      Boolean       @default(false)
  status        String        @default("completed")
  seoTitle      String?
  seoDescription String?
  seoKeywords   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  projectLinks  ProjectLink[]

  @@index([featured])
  @@index([createdAt(sort: Desc)])
  @@index([slug])
}

model ProjectLink {
  id        String  @id @default(cuid())
  label     String
  url       String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String
  contentFormat String   @default("mdx")
  coverImage    String?
  published     Boolean  @default(false)
  readingTime   Int      @default(1)
  seoTitle      String?
  seoDescription String?
  seoKeywords   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tags          String[]

  @@index([published])
  @@index([createdAt(sort: Desc)])
  @@index([slug])
}

// ─── Experience ──────────────────────────────────────────────────────────────

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  location    String?
  type        String   @default("Full-time")
  startDate   DateTime
  endDate     DateTime?
  current     Boolean  @default(false)
  description String
  skills      String[]
  logoUrl     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([order])
}

// ─── Skills ──────────────────────────────────────────────────────────────────

model Skill {
  id       String  @id @default(cuid())
  name     String  @unique
  category String
  iconUrl  String?
  order    Int     @default(0)

  @@index([order])
  @@index([category])
}

// ─── Contact Messages ────────────────────────────────────────────────────────

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Hackathons ──────────────────────────────────────────────────────────────

model Hackathon {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  project     String
  role        String?
  date        DateTime
  location    String?
  result      String?
  link        String?
  description String
  image       String?
  createdAt   DateTime @default(now())

  @@index([date(sort: Desc)])
  @@index([slug])
}

// ─── Certifications ──────────────────────────────────────────────────────────

model Certification {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  issuer       String
  date         DateTime
  url          String?
  credentialId String?
  image        String?
  createdAt    DateTime @default(now())

  @@index([date(sort: Desc)])
  @@index([slug])
}

// ─── Education ───────────────────────────────────────────────────────────────

model Education {
  id          String   @id @default(cuid())
  slug        String   @unique
  institution String
  degree      String
  field       String?
  startYear   String
  endYear     String?
  current     Boolean  @default(false)
  description String?
  gpa         String?
  location    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([order])
  @@index([slug])
}

// ─── Page Views (Analytics) ──────────────────────────────────────────────────

model PageView {
  id    String @id @default(cuid())
  path  String @unique
  count Int    @default(0)
}
